# ------------------------------------------------------------
# ENDevo Q12 — environment variables (set in Vercel for prod)
# Copy to .env.local for local dev; never commit real secrets.
# ------------------------------------------------------------

# AWS SES — the From address must be a verified SES identity.
SES_FROM="ENDevo <hello@endevo.life>"

# AWS region where SES is configured
AWS_REGION=us-east-1

# AWS credentials for SES send. Scope to ses:SendRawEmail only.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# GHL inbound webhook URL — payload shape in src/lib/engine.ts :: toGHLPayload
GHL_WEBHOOK_URL=

# Claude API key — unused until getStaticWrapper is swapped for a live call.
# Leave blank for v1.
ANTHROPIC_API_KEY=
